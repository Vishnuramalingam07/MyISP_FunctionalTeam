# PostgreSQL Database Configuration for MyISP Tools
# Copy this to .env and modify for your setup

# ============================================================
# For Server (Database Host)
# ============================================================
# Use these defaults - database listens on all network interfaces
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=myisp_tools  
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres123

# ============================================================
# For Team Members (Connecting to Shared Database)
# ============================================================
# Uncomment and modify to connect to the shared database server
# POSTGRES_HOST=192.168.1.2
# POSTGRES_PORT=5432
# POSTGRES_DB=myisp_tools
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres123

# Default values (used if not set):
# - Host: localhost
# - Port: 5432
# - Database: myisp_tools
# - User: postgres
# - Password: postgres123
